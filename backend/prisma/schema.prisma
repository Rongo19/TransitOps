generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  ACTIVE
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
}

model Vehicle {
  id                  String        @id @default(cuid())
  registrationNumber  String        @unique
  name                String
  type                String
  maxLoadCapacity     Float
  odometer            Float         @default(0)
  acquisitionCost     Float
  status              VehicleStatus @default(AVAILABLE)
  createdAt           DateTime      @default(now())

  trips          Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([status])
}

model Driver {
  id                 String       @id @default(cuid())
  name               String
  licenseNumber      String       @unique
  licenseCategory    String
  licenseExpiryDate  DateTime
  contactNumber      String
  safetyScore        Int          @default(100)
  status             DriverStatus @default(AVAILABLE)
  createdAt          DateTime     @default(now())

  trips Trip[]

  @@index([status])
}

model Trip {
  id              String     @id @default(cuid())
  tripCode        String     @unique
  source          String
  destination     String
  vehicleId       String?
  driverId        String?
  cargoWeight     Float
  plannedDistance Float
  finalOdometer   Float?
  fuelConsumed    Float?
  status          TripStatus @default(DRAFT)
  createdAt       DateTime   @default(now())
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?

  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  driver  Driver?  @relation(fields: [driverId], references: [id])

  fuelLogs FuelLog[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceLog {
  id          String            @id @default(cuid())
  vehicleId   String
  serviceType String
  cost        Float
  date        DateTime
  status      MaintenanceStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  tripId    String?
  liters    Float
  cost      Float
  date      DateTime
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?    @relation(fields: [tripId], references: [id])

  @@index([vehicleId])
}

model Expense {
  id          String   @id @default(cuid())
  vehicleId   String
  category    String   // e.g. "Toll", "Parking", "Fine"
  amount      Float
  date        DateTime
  createdAt   DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId])
}